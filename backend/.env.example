DATABASE_URL=postgresql://techpotli:techpotli@localhost:5433/techpotli_os?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-min-32-characters-long-secret
JWT_REFRESH_SECRET=change-me-min-32-characters-refresh-secret
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
FRONTEND_URL=http://localhost:3000
# Optional extra browser origins (comma-separated), e.g. Vercel preview URLs
# CORS_ORIGINS=https://techpotli-crm.vercel.app
BACKEND_URL=http://localhost:3001
# Optional cookie overrides (production split-origin): COOKIE_SAME_SITE=lax|none|strict, COOKIE_SECURE=true|false
PORT=3001
JWT_ACCESS_EXPIRES=15m
ALLOWED_OFFICE_IPS=127.0.0.1/32,152.56.178.15/32

# AWS S3 — copy exact bucket name from S3 console (Account Regional buckets get a long suffix)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# Email — Resend (recommended, 3000 emails/month free)
# https://resend.com → API Keys + verify domain (or use onboarding@resend.dev for testing)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=support@techpotli.com
RESEND_REPLY_TO=support@techpotli.com
# While using onboarding@resend.dev, invoices can ONLY be sent to this inbox
RESEND_TEST_TO=onboarding@techpotli.com
MAIL_FROM_NAME=TechPotli

# Email — Gmail fallback (optional if not using Resend)
# GMAIL_USER=support@techpotli.in
# GMAIL_APP_PASSWORD=your16charapppassword

# Background jobs (follow-up reminders, renewal checks, quotation expiry)
# Requires Redis running — e.g. docker run -p 6379:6379 redis:7-alpine
ENABLE_CRON_JOBS=true

# Event bus (Redpanda/Kafka) — docker compose includes redpanda
ENABLE_KAFKA=true
KAFKA_BROKERS=localhost:9092

# AI (Ollama) — docker compose includes ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Read replica (optional — defaults to DATABASE_URL)
DATABASE_READ_URL=postgresql://techpotli:techpotli@localhost:5432/techpotli_os?schema=public

# Analytics (optional)
ENABLE_CLICKHOUSE=false
CLICKHOUSE_URL=http://localhost:8123

# Redis sharding nodes for consistent hashing
REDIS_SHARD_NODES=shard-0,shard-1,shard-2
