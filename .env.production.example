# =============================================================================
# TechPotli CRM — Production environment
# Copy to .env.production and fill every value before going live.
# Generate secrets: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# =============================================================================

# --- Domain (replace with your live URL) ---
FRONTEND_URL=https://crm.techpotli.com
BACKEND_URL=https://crm.techpotli.com/api
PUBLIC_API_URL=https://crm.techpotli.com/api
PUBLIC_WS_URL=https://crm.techpotli.com

# --- Database ---
POSTGRES_USER=techpotli
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=techpotli_os

# --- Auth secrets (64-char hex each — NEVER use example values) ---
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_HEX
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_HEX
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX
JWT_ACCESS_EXPIRES=30m
JWT_REFRESH_EXPIRES=7d

# --- Email (Resend — required for invoices & customer emails) ---
# https://resend.com → verify domain techpotli.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=support@techpotli.com
RESEND_REPLY_TO=support@techpotli.com
MAIL_FROM_NAME=TechPotli

# --- File storage (AWS S3 — required for PDFs in production) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=techpotli-crm-files
AWS_REGION=ap-south-1

# --- HTTP port (use 80; put SSL in front with Caddy/Certbot) ---
HTTP_PORT=80
