# Database (Development - Docker)
DATABASE_URL=postgresql://techpotli:techpotli@localhost:5432/techpotli_os?schema=public

# Redis (Development - Docker)
REDIS_URL=redis://localhost:6379

# JWT (generate secure random strings for production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Encryption (32-byte hex key for AES-256-GCM)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# Email (Gmail SMTP)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Application URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# Office IP whitelist (comma-separated, also managed in DB)
ALLOWED_OFFICE_IPS=127.0.0.1/32

# Production (Railway)
# DATABASE_URL=postgresql://user:pass@host:5432/railway?schema=public&connection_limit=10
# REDIS_URL=redis://default:pass@host:6379
